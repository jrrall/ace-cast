<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="stylesheet" href="/css/theme.css">
    <link rel="stylesheet" href="/css/host.css">
</head>
<body>
    <div class="container">
        <header>
            <h1>🃏 unholy.cards</h1>
            <p>Summon your crew. Cast to the TV, play from your phone.</p>
        </header>

        <main>
            <div id="setup-screen" class="screen active">
                <div class="setup-card">
                    <h2>Start Your Game</h2>
                    <button id="create-room-btn" class="primary-btn">Create Room</button>
                    <p class="help-text">This will create a room code for players to join</p>
                </div>
            </div>

            <div id="room-screen" class="screen">
                <div class="room-info">
                    <h2>Room Created!</h2>
                    <div class="room-code-display">
                        <span class="label">Room Code:</span>
                        <span id="room-code" class="room-code"></span>
                    </div>
                    
                    <div class="qr-section">
                        <h3>Players can scan to join:</h3>
                        <div id="qr-code-container"></div>
                        <a id="join-play-link" href="#" class="play-link">Play on this phone →</a>
                        <p class="join-url">Or visit: <a id="join-url" href="#"></a></p>
                    </div>

                    <div class="tv-section">
                        <h3>Cast to TV:</h3>
                        <a id="tv-url" href="#" target="_blank" class="tv-link">Open TV Display</a>
                        <p class="help-text">Open this link on your Chromecast or TV browser</p>
                    </div>
                </div>

                <div class="players-section">
                    <h3>At the table (<span id="player-count">0</span>)</h3>
                    <div class="bot-controls">
                        <button id="remove-bot-btn" class="secondary-btn" type="button">− Bot</button>
                        <span id="bot-hint" class="help-text">Bots fill the table once 2 people join — they play cards, humans are the Czar.</span>
                        <button id="add-bot-btn" class="secondary-btn" type="button">+ Bot</button>
                    </div>
                    <ul id="players-list"></ul>
                </div>

                <div class="game-controls">
                    <h3>Game Options</h3>
                    <p class="help-text" id="countdown-status"></p>
                    <div class="start-controls">
                        <button id="start-game-btn" class="primary-btn" disabled>Start now</button>
                        <button id="autostart-toggle-btn" class="secondary-btn" type="button">Hold</button>
                    </div>
                    <button id="end-game-btn" class="secondary-btn" style="display: none;">End Game</button>
                </div>

                <div class="game-status">
                    <h3>Game Status</h3>
                    <div id="game-status-content">
                        <p>Waiting for players to join...</p>
                    </div>
                </div>
            </div>
        </main>
    </div>

    <script src="/socket.io/socket.io.js"></script>
    <script src="/js/host.js"></script>
</body>
</html>