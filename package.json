{
  "name": "ace-cast",
  "version": "1.10.0",
  "description": "A Chromecast-powered card game engine for instant party gaming",
  "main": "src/server/index.js",
  "scripts": {
    "start": "node src/server/index.js",
    "dev": "nodemon src/server/index.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src/ --ext .js",
    "lint:fix": "eslint src/ --ext .js --fix",
    "migrate": "knex --knexfile src/db/knexfile.js migrate:latest",
    "migrate:make": "knex --knexfile src/db/knexfile.js migrate:make",
    "migrate:rollback": "knex --knexfile src/db/knexfile.js migrate:rollback",
    "seed:make": "knex --knexfile src/db/knexfile.js seed:make",
    "seed:run": "knex --knexfile src/db/knexfile.js seed:run",
    "semantic-release": "semantic-release"
  },
  "keywords": [
    "chromecast",
    "party-games",
    "card-games",
    "multiplayer",
    "websockets"
  ],
  "author": "Your Name",
  "license": "MIT",
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "better-sqlite3": "^12.11.1",
    "cors": "^2.8.5",
    "ejs": "^3.1.10",
    "express": "^5.1.0",
    "knex": "^3.3.0",
    "pg": "^8.22.0",
    "qrcode": "^1.5.4",
    "socket.io": "^4.8.1",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.0.0",
    "@commitlint/config-conventional": "^20.0.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^11.0.6",
    "eslint": "^8.57.1",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-plugin-import": "^2.32.0",
    "jest": "^30.1.3",
    "nodemon": "^3.1.10",
    "semantic-release": "^24.2.9",
    "socket.io-client": "^4.8.3",
    "supertest": "^7.1.4"
  }
}
