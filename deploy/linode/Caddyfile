# Caddy reverse proxy for Ace Cast.
#
# Caddy automatically provisions + renews a Let's Encrypt TLS cert for SITE_ADDRESS
# (needs the domain's A record pointing here and ports 80/443 reachable), and
# `reverse_proxy` proxies WebSockets transparently — no Upgrade/Connection header
# juggling like nginx needs. Socket.IO just works.
#
# For a local run, set SITE_ADDRESS=localhost: Caddy serves HTTPS with its own
# internal cert and skips Let's Encrypt entirely.
#
# E4 accounts: gameplay stays 100% public. Only /account* and /admin* are gated
# by Authelia via forward-auth — on success Authelia returns Remote-User /
# Remote-Email / Remote-Name / Remote-Groups, which we copy onto the upstream
# request so the app can trust them (it only does so because TRUST_PROXY=true).
{$SITE_ADDRESS} {
	encode zstd gzip

	# Authelia's own portal (login page + verify endpoint), served under /authelia
	# so it shares the app's domain. Use `handle` (NOT handle_path) so the prefix
	# is preserved — Authelia is configured to serve under /authelia, so its
	# assets + /authelia/api/* line up. `handle` blocks are mutually exclusive,
	# so this and the app block below never fight over a path.
	handle /authelia/* {
		reverse_proxy authelia:9091
	}

	# Everything else. Account + admin surfaces are gated by Authelia forward-auth
	# (unauthenticated → redirected to the portal); every other path — create/join/
	# play, TV, health — is public. Wrapped in `handle` so it's the exclusive
	# fallthrough after the /authelia block.
	handle {
		@protected path /account /account/* /admin /admin/*
		forward_auth @protected authelia:9091 {
			uri /authelia/api/verify?rd=https://{$SITE_ADDRESS}/authelia/
			copy_headers Remote-User Remote-Email Remote-Name Remote-Groups
		}

		reverse_proxy app:3000
	}
}
