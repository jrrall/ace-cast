# Copy to `.env` in this directory and fill in. NEVER commit the real .env.
#   cp .env.sqlite.example .env && nano .env
#
# SQLite deploy needs only these two — there is no database server to credential.

# Your domain, with a DNS A record pointing at this server's public IPv4.
# Caddy fetches a TLS cert for exactly this name.
SITE_ADDRESS=acecast.example.com

# Public origin players hit. Must be https and match SITE_ADDRESS — it's what
# QR codes, join links, and the TV URL are built from.
PUBLIC_URL=https://acecast.example.com
