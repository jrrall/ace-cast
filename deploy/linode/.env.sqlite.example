# Copy to `.env` in this directory and fill in. NEVER commit the real .env.
#   cp .env.sqlite.example .env && nano .env
#
# SQLite deploy needs only these two — there is no database server to credential.

# Your domain, with a DNS A record pointing at this server's public IPv4.
# Caddy fetches a TLS cert for exactly this name.
SITE_ADDRESS=acecast.example.com

# Public origin players hit. Must be https and match SITE_ADDRESS — it's what
# QR codes, join links, and the TV URL are built from.
PUBLIC_URL=https://acecast.example.com

# --- E4 accounts (Authelia forward-auth). All CLEARLY-FAKE placeholders. ---
# Gameplay stays public; these only gate /account* and /admin*.

# App session cookie signing secret (the app's own login session). Any long
# random string. Generate: openssl rand -hex 32
AUTH_SESSION_SECRET=change-me-app-session-secret-0000000000000000000000000000000000000000

# Authelia secrets — generate each independently, e.g. openssl rand -hex 32.
# NEVER commit the real values.
AUTHELIA_JWT_SECRET=change-me-authelia-jwt-secret-000000000000000000000000000000000000000
AUTHELIA_SESSION_SECRET=change-me-authelia-session-secret-00000000000000000000000000000000
AUTHELIA_STORAGE_ENCRYPTION_KEY=change-me-authelia-storage-key-0000000000000000000000000000000
